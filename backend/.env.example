# VerdantAI Backend - Environment Variables
# Copy this file to .env and fill in your values.
# If omitted, the app runs in local fallback mode automatically.

# Gemini AI API Key (Get yours from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Storage Credentials (Optional, falls back to local storage if omitted)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Your deployed Vercel frontend URL (used for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Flask Server Port (Optional, defaults to 5000)
PORT=5000
